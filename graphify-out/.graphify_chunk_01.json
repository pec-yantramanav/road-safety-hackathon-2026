      "id": "master_ticket_clustering",
      "label": "MasterTicket Spatial Clustering Mechanism",
      "file_type": "document",
      "source_file": "docs/Design Docs/java_citizen_core_api_lld.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Deduplicates multiple reports of the same physical road issue (within a 50m radius) into a single MasterTicket, avoiding overwhelming officials with duplicate complaints while tracking community interest via contribution counts and auto-upgrading priority."
    },
    {
      "id": "grievance_escalation_pipeline",
      "label": "Grievance Escalation Pipeline",
      "file_type": "document",
      "source_file": "docs/Design Docs/java_crm_core_api_lld.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Redesigned for rapid resolution compared to CPGRAMS's slow bureaucratic escalation. Uses real-time status updates via WebSockets, SLA timers, auto-escalation, and blackspot overrides to bypass junior levels for critical accident-prone areas."
    },
    {
      "id": "pow_validation_pipeline",
      "label": "Proof-of-Work (PoW) Validation Pipeline",
      "file_type": "document",
      "source_file": "docs/Design Docs/python_crm_ai_service_lld.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Ensures accountability by requiring contractors to upload before/after photos and geotags. Automates verification through a Python AI service checking EXIF data and visual change via LLM vision to prevent false resolutions."
    },
    {
      "id": "role_based_access_control_rls",
      "label": "Role-Based Access Control and Row-Level Security",
      "file_type": "document",
      "source_file": "docs/Design Docs/java_crm_core_api_lld.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Ensures data visibility is automatically scoped to each user's jurisdiction (e.g. Ward Engineer sees Ward 42 tickets; NHAI GM sees corridor). Essential for driving adoption among Indian government officials by mirroring their operational workflows and enabling sandboxed contractor portals."
    },
    {
      "id": "agentic_ai_chat_interface",
      "label": "Agentic AI Multilingual Chatbot Interface",
      "file_type": "document",
      "source_file": "docs/plan.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Provides a highly accessible, conversational, and multilingual entry point for citizens to report issues, track tickets, or query budgets without navigating complex menus."
    }
